# Server
PORT=8080
ENV=development
LOG_LEVEL=info

# Database (managed inside the container; override only if using an external DB)
DATABASE_URL=postgres://tma_user:tma_password@localhost:5432/tma_boilerplate?sslmode=disable

# Telegram — get your token from @BotFather
TELEGRAM_BOT_TOKEN=
# Bot username without the @ — used to build the "Continue in Telegram" deep link
TELEGRAM_BOT_USERNAME=

# Telegram Mini App — public HTTPS URL where the Vue frontend is served.
# In dev this gets overwritten automatically with the ngrok tunnel URL on startup —
# only set it for real in production.
TELEGRAM_MINI_APP_URL=https://your-public-domain.com

# Telegram webhook — set for production; leave empty in dev (ngrok auto-discovery is used)
WEBHOOK_URL=

# ngrok — dev only; get your token at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# JWT — use a random 32+ character string in production
JWT_SECRET=change-this-in-production-min-32-chars
JWT_EXPIRATION_HOURS=720

# CORS (comma-separated; in production set to your public domain)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# Admin panel — set a strong random token to protect the admin API
ADMIN_TOKEN=change-this-to-a-strong-random-token
