# Server
PORT=8080
ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://tma_user:tma_password@localhost:5432/tma_boilerplate?sslmode=disable

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Google Gemini API — get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# JWT (use a random 32+ char string in production)
JWT_SECRET=change-this-to-a-random-32-char-secret
JWT_EXPIRATION_HOURS=720

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Telegram Mini App URL
TELEGRAM_MINI_APP_URL=https://yourdomain.com

# Stripe (optional, for card payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
